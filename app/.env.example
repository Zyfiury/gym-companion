# Copy to .env and fill in your values. Never commit real .env to git.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

GROQ_API_KEY=your-groq-key

# Use PUBLIC SDK key from RevenueCat (goog_... or appl_...), NOT sk_ secret
REVENUECAT_KEY=goog_your_public_key

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_ANDROID_APP_ID=1:123:android:abc
FIREBASE_WEB_APP_ID=1:123:web:abc
FIREBASE_APP_ID=1:123:android:abc
FIREBASE_IOS_APP_ID=1:123:ios:abc
FIREBASE_IOS_BUNDLE_ID=com.gymcompanion.gymCompanion

YOUTUBE_API_KEY=optional-youtube-key

# Google Places — nearby restaurant/supermarket search
GOOGLE_PLACES_API_KEY=

# Google Cloud Vision — required for camera meal scan (no mock fallback in release)
GOOGLE_VISION_API_KEY=

OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=

# DEBUG ONLY — must be absent or false for Play Store release builds
# DEV_PRO_OVERRIDE=true

# Set true when building APKs for friends to sideload (enables test login on release builds)
ALLOW_SIDELOAD_TESTER=true
